{
  "name": "aws-iam-policy-validator",
  "displayName": "AWS IAM Policy Validator",
  "description": "Validates AWS IAM policy files: checks for malformed JSON, structural issues, and character limits (managed 6,144 / inline 2,048)",
  "version": "0.1.0",
  "publisher": "ParasBhangalia",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/parasbhangalia/aws-iam-policy-validator"
  },
  "homepage": "https://github.com/parasbhangalia/aws-iam-policy-validator#readme",
  "bugs": {
    "url": "https://github.com/parasbhangalia/aws-iam-policy-validator/issues"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": ["Linters"],
  "activationEvents": [
    "onLanguage:json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aws-iam-policy-validator.validate",
        "title": "AWS IAM: Validate Current Policy",
        "category": "AWS IAM"
      },
      {
        "command": "aws-iam-policy-validator.validateAll",
        "title": "AWS IAM: Validate All Policies in Workspace",
        "category": "AWS IAM"
      }
    ],
    "keybindings": [
      {
        "command": "aws-iam-policy-validator.validate",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p",
        "when": "editorLangId == json"
      }
    ],
    "configuration": {
      "title": "AWS IAM Policy Validator",
      "properties": {
        "awsIamPolicyValidator.managedPolicyLimit": {
          "type": "number",
          "default": 6144,
          "description": "AWS managed policy character limit (minified JSON). Default: 6144."
        },
        "awsIamPolicyValidator.inlinePolicyLimit": {
          "type": "number",
          "default": 2048,
          "description": "AWS inline policy character limit (minified JSON). Default: 2048."
        },
        "awsIamPolicyValidator.warningThresholdPercent": {
          "type": "number",
          "default": 90,
          "description": "Percentage of limit at which a warning is shown (0-100). Default: 90."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.0.0"
  }
}
